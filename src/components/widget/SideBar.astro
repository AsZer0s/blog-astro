---
import type { MarkdownHeading } from "astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import Tag from "./Tags.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const className = Astro.props.class;
---
<div id="sidebar" class:list={[className, "w-full"]}>
    <div class="flex flex-col w-full gap-4 mb-4">
        <Profile></Profile>
    </div>
    <div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4">
        <Categories class="onload-animation" style="animation-delay: 150ms"></Categories>
        <Tag class="onload-animation" style="animation-delay: 200ms"></Tag>
        <div style="display:flex;justify-content:center;align-items:center;gap:8px;">
            <a href="https://www.blogsclub.org/certificate.html?id=10000146" target="_blank" rel="noopener noreferrer">
                <img src="https://www.blogsclub.org/images/blue-cert.png" style="width:117px;height:40px;" alt="博客联盟认证" />
            </a>
            <a href="https://www.blogsclub.org/rank.html" target="_blank">
                <img src="https://www.blogsclub.org/badge/blog.hiyun.top" 
                    style="height:60px!important">
            </a>
        </div>
    </div>
</div>
